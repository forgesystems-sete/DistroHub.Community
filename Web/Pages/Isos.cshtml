@page "/isos"
@{
    ViewData["Title"] = "ISOs — DistroHub Community";
    Layout = "_Layout";
}
<div class="container" style="padding: 64px 0; text-align: center;">
    <div style="font-size: 64px; margin-bottom: 24px;">📦</div>
    <h1 style="color: var(--accent); margin-bottom: 16px;">Gerenciamento de ISOs</h1>
    <p style="color: var(--muted); margin-bottom: 32px; font-size: 18px; max-width: 600px; margin-left: auto; margin-right: auto;">
        Em breve você poderá fazer upload, verificar checksum SHA-256 e gerenciar suas próprias ISOs diretamente pelo painel administrativo.
    </p>
    <div style="background: var(--surface); border-radius: 12px; padding: 24px; display: inline-block; border: 1px solid var(--border);">
        <span style="color: var(--accent); font-weight: 700;">🚧 Disponível nas edições Standard e Professional</span>
    </div>
    <p style="margin-top: 32px;">
        <a href="/planos" class="btn btn-primary">Conheça os planos</a>
    </p>
</div>
