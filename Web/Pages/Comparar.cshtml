@page "/comparar"
@{
    ViewData["Title"] = "Comparar Distros — DistroHub Community";
    Layout = "_Layout";
}
<div class="container" style="padding: 64px 0; text-align: center;">
    <div style="font-size: 64px; margin-bottom: 24px;">⚖️</div>
    <h1 style="color: var(--accent); margin-bottom: 16px;">Comparação lado a lado</h1>
    <p style="color: var(--muted); margin-bottom: 32px; font-size: 18px; max-width: 600px; margin-left: auto; margin-right: auto;">
        Compare até 3 distribuições simultaneamente: versão, ambiente desktop, gerenciador de pacotes, arquiteturas e muito mais.
    </p>
    <div style="background: var(--surface); border-radius: 12px; padding: 24px; display: inline-block; border: 1px solid var(--border);">
        <span style="color: var(--accent); font-weight: 700;">🔒 Exclusivo para Professional</span>
    </div>
    <p style="margin-top: 32px;">
        <a href="/planos" class="btn btn-primary">Fazer upgrade para Professional</a>
    </p>
</div>
