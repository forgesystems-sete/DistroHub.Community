@page
@model DistroHub.Web.Pages.IndexModel
@using DistroHub.Domain.Enums
@using DistroHub.Web.Helpers
@{
    ViewData["Title"] = "DistroHub Community — Catálogo Linux";

    string FiltroUrl(string param, string? valor)
    {
        var q   = HttpContext.Request.Query["q"].FirstOrDefault();
        var cat = HttpContext.Request.Query["cat"].FirstOrDefault();
        var de  = HttpContext.Request.Query["de"].FirstOrDefault();
        var pm  = HttpContext.Request.Query["pm"].FirstOrDefault();
        var rol = HttpContext.Request.Query["rolling"].FirstOrDefault();
        switch (param)
        {
            case "cat": cat = valor; break;
            case "de":  de  = valor; break;
            case "pm":  pm  = valor; break;
            case "rolling": rol = valor; break;
            case "q":   q   = valor; break;
        }
        var parts = new System.Collections.Generic.List<string>();
        if (!string.IsNullOrEmpty(q))   parts.Add("q="      + Uri.EscapeDataString(q));
        if (!string.IsNullOrEmpty(cat)) parts.Add("cat="    + cat);
        if (!string.IsNullOrEmpty(de))  parts.Add("de="     + de);
        if (!string.IsNullOrEmpty(pm))  parts.Add("pm="     + pm);
        if (!string.IsNullOrEmpty(rol)) parts.Add("rolling="+ rol);
        return "/?" + string.Join("&", parts);
    }
    string CatAtiva(Category c)      => Model.Cat == (int)c ? "active" : "";
    string DeAtiva(DesktopEnv d)     => Model.De  == (int)d ? "active" : "";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"]</title>
  <style>
    :root{--bg:#080c14;--surface:#0e1420;--card:#121826;--border:#1d2535;--accent:#00d4ff;--accent2:#0099cc;--green:#00e676;--purple:#b388ff;--orange:#ff9d00;--red:#ff5252;--text:#dde4f0;--muted:#546e8a;--glow:rgba(0,212,255,.12);}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--bg);color:var(--text);font-family:system-ui,-apple-system,"Segoe UI",sans-serif;min-height:100vh;background-image:radial-gradient(ellipse at 20% 0%,rgba(0,212,255,.04) 0%,transparent 50%),radial-gradient(ellipse at 80% 100%,rgba(179,136,255,.03) 0%,transparent 50%);}
    nav{border-bottom:1px solid var(--border);padding:0 40px;height:62px;display:flex;align-items:center;gap:20px;background:rgba(8,12,20,.9);backdrop-filter:blur(16px);position:sticky;top:0;z-index:50;}
    .n-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
    .n-logo-icon{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,var(--accent),var(--purple));display:flex;align-items:center;justify-content:center;font-size:16px;}
    .n-logo-text{font-family:monospace;font-size:15px;font-weight:700;color:var(--text);}
    .n-logo-text span{color:var(--accent);}
    .n-links{display:flex;gap:2px;margin-left:20px;}
    .n-link{padding:6px 13px;font-size:13px;font-weight:500;color:var(--muted);border-radius:6px;transition:.15s;text-decoration:none;}
    .n-link:hover{color:var(--text);background:rgba(255,255,255,.04);}
    .n-link.active{color:var(--accent);}
    .n-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
    .n-search{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:7px 14px;font-size:12px;color:var(--text);outline:none;width:200px;font-family:inherit;transition:.2s;}
    .n-search:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--glow);}
    .n-search::placeholder{color:var(--muted);}
    .hero{padding:56px 40px 48px;text-align:center;position:relative;overflow:hidden;}
    .hero::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(0,212,255,.07) 0%,transparent 70%);pointer-events:none;}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:6px;border:1px solid rgba(0,212,255,.2);background:rgba(0,212,255,.06);color:var(--accent);font-size:11px;font-weight:700;padding:4px 14px;border-radius:20px;font-family:monospace;letter-spacing:.08em;margin-bottom:22px;}
    .hero h1{font-size:42px;font-weight:700;letter-spacing:-.03em;margin-bottom:14px;line-height:1.15;}
    .hero h1 span{color:var(--accent);}
    .hero-desc{font-size:15px;color:var(--muted);max-width:540px;margin:0 auto 30px;line-height:1.7;}
    .hero-stats{display:flex;align-items:center;justify-content:center;gap:32px;margin-bottom:32px;}
    .hstat{text-align:center;}
    .hstat-val{font-family:monospace;font-size:24px;font-weight:700;color:var(--text);}
    .hstat-val span{color:var(--accent);}
    .hstat-label{font-size:11px;color:var(--muted);margin-top:2px;letter-spacing:.06em;text-transform:uppercase;}
    .hero-actions{display:flex;align-items:center;justify-content:center;gap:12px;}
    .btn-lg-cyan{padding:11px 28px;font-size:14px;font-weight:700;background:var(--accent);color:#080c14;border:none;border-radius:8px;cursor:pointer;font-family:inherit;transition:.15s;text-decoration:none;display:inline-block;}
    .btn-lg-cyan:hover{background:var(--accent2);}
    .btn-lg-ghost{padding:11px 28px;font-size:14px;font-weight:700;background:transparent;color:var(--text);border:1px solid var(--border);border-radius:8px;cursor:pointer;font-family:inherit;transition:.15s;text-decoration:none;display:inline-block;}
    .btn-lg-ghost:hover{border-color:var(--accent);color:var(--accent);}
    .main-wrap{max-width:1200px;margin:0 auto;padding:36px 40px;}
    .filter-bar{display:flex;align-items:center;gap:10px;margin-bottom:28px;flex-wrap:wrap;}
    .section-label{font-family:monospace;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-right:6px;}
    .fchip{padding:5px 14px;border-radius:20px;font-size:12px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);font-family:inherit;transition:.15s;text-decoration:none;display:inline-block;}
    .fchip:hover{border-color:var(--accent);color:var(--accent);}
    .fchip.active{background:rgba(0,212,255,.12);border-color:var(--accent);color:var(--accent);}
    .fchip.green{border-color:var(--green);color:var(--green);background:rgba(0,230,118,.06);}
    .fchip.green.active{background:rgba(0,230,118,.15);}
    .fchip.red{border-color:var(--red);color:var(--red);}
    .distro-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:40px;}
    .distro-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:20px;transition:.25s;position:relative;overflow:hidden;animation:fadeUp .5s ease both;display:flex;flex-direction:column;}
    .distro-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent);opacity:0;transition:.25s;}
    .distro-card:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,0,0,.4);}
    .distro-card:hover::before{opacity:1;}
    .distro-card.featured{border-color:rgba(0,212,255,.3);background:linear-gradient(135deg,rgba(0,212,255,.04),var(--card));}
    .distro-card.featured::before{opacity:.6;}
    .dc-top{display:flex;align-items:flex-start;gap:14px;margin-bottom:14px;}
    .dc-logo{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;background:linear-gradient(135deg,var(--accent),var(--purple));}
    .dc-info{flex:1;}
    .dc-name{font-size:16px;font-weight:700;letter-spacing:-.01em;margin-bottom:3px;}
    .dc-base{font-size:11px;color:var(--muted);font-family:monospace;}
    .dc-badges{display:flex;gap:5px;margin-top:4px;flex-wrap:wrap;}
    .dc-badge{font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;font-family:monospace;letter-spacing:.06em;text-transform:uppercase;}
    .badge-cyan{background:rgba(0,212,255,.1);color:var(--accent);}
    .badge-green{background:rgba(0,230,118,.1);color:var(--green);}
    .badge-purple{background:rgba(179,136,255,.1);color:var(--purple);}
    .badge-orange{background:rgba(255,157,0,.1);color:var(--orange);}
    .badge-featured{background:rgba(0,212,255,.15);color:var(--accent);border:1px solid rgba(0,212,255,.3);}
    .dc-desc{font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:14px;flex:1;}
    .dc-footer{display:flex;align-items:center;gap:10px;margin-top:auto;}
    .dc-stat{font-size:11px;color:var(--muted);font-family:monospace;}
    .dc-ver{margin-left:auto;font-size:11px;color:var(--accent);font-family:monospace;font-weight:700;}
    .dc-dl-btn{display:flex;align-items:center;gap:5px;padding:6px 12px;border-radius:6px;font-size:11px;font-weight:700;background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.2);color:var(--accent);font-family:inherit;transition:.15s;text-decoration:none;}
    .dc-dl-btn:hover{background:rgba(0,212,255,.15);}
    .bottom-grid{display:grid;grid-template-columns:1fr 320px;gap:20px;}
    .b-card{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;}
    .b-header{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
    .b-title{font-family:monospace;font-size:12px;font-weight:700;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;}
    .upload-zone{padding:20px;}
    .upz-inner{border:2px dashed var(--border);border-radius:10px;padding:32px 20px;text-align:center;}
    .upz-icon{font-size:32px;margin-bottom:10px;}
    .upz-title{font-size:14px;font-weight:700;margin-bottom:5px;}
    .upz-desc{font-size:12px;color:var(--muted);line-height:1.5;}
    .recent-item{display:flex;align-items:center;gap:12px;padding:13px 20px;border-bottom:1px solid var(--border);transition:.15s;}
    .recent-item:hover{background:rgba(255,255,255,.02);}
    .recent-item:last-child{border-bottom:none;}
    .ri-logo{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;background:linear-gradient(135deg,var(--accent),var(--purple));}
    .ri-name{font-size:13px;font-weight:700;}
    .ri-version{font-size:11px;color:var(--muted);font-family:monospace;}
    .ri-size{font-size:11px;color:var(--muted);font-family:monospace;margin-left:auto;white-space:nowrap;}
    .vazio{grid-column:1/-1;text-align:center;padding:4rem;color:var(--muted);}
    @@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
    @@media(max-width:900px){.distro-grid{grid-template-columns:repeat(2,1fr);}.bottom-grid{grid-template-columns:1fr;}}
    @@media(max-width:600px){nav{padding:0 16px;}.hero{padding:32px 16px 24px;}.main-wrap{padding:24px 16px;}.distro-grid{grid-template-columns:1fr;}.hero h1{font-size:28px;}.hero-stats{gap:16px;}}
  </style>
</head>
<body>

<nav>
  <a href="/" class="n-logo">
    <div class="n-logo-icon">🐧</div>
    <span class="n-logo-text">Distro<span>Hub</span></span>
  </a>
  <div class="n-links">
    <a href="/" class="n-link active">Catálogo</a>
    <a href="/isos" class="n-link">ISOs</a>
    <a href="/comparar" class="n-link">Comparar</a>
    <a href="/sobre" class="n-link">Sobre</a>
    <a href="/planos" class="n-link">Planos</a>
  </div>
  <div class="n-right">
    <form method="get" action="/" style="display:contents;">
      <input class="n-search" name="q" value="@Model.Search" placeholder="🔍 Buscar distro..." />
    </form>
  </div>
</nav>

<div class="hero">
  <div class="hero-eyebrow">🐧 CATÁLOGO LINUX · OPEN SOURCE</div>
  <h1>Descubra a <span>distribuição perfeita</span></h1>
  <p class="hero-desc">O maior catálogo brasileiro de distribuições Linux, com ISOs verificados por checksum, bot Telegram para atualizações e comparativo detalhado.</p>
  <div class="hero-stats">
    <div class="hstat">
      <div class="hstat-val"><span>@Model.TotalCount</span></div>
      <div class="hstat-label">Distros</div>
    </div>
    <div class="hstat">
      <div class="hstat-val"><span>@Model.Distros.Sum(d => d.DownloadCount)</span></div>
      <div class="hstat-label">Downloads</div>
    </div>
    <div class="hstat">
      <div class="hstat-val"><span>100%</span></div>
      <div class="hstat-label">Checksum</div>
    </div>
  </div>
  <div class="hero-actions">
    <a href="#catalogo" class="btn-lg-cyan">Explorar catálogo</a>
    <a href="/sobre#telegram" class="btn-lg-ghost">🤖 Bot Telegram</a>
  </div>
</div>

<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; padding: 0 40px;"> 
    <h2>Catálogo de Demonstração</h2> 
    <span style="background: rgba(0,212,255,0.15); color: var(--accent); padding: 6px 16px; border-radius: 20px;"> 
        📦 @Model.Distros.Count() de 120+ distros 
    </span> 
</div> 
<p style="color: var(--muted); margin-bottom: 24px; padding: 0 40px;"> 
    Esta é uma amostra do catálogo completo. 
    <a href="/planos" style="color: var(--accent);">Faça upgrade para acessar todas as distros.</a>
</p>

<div class="main-wrap" id="catalogo">
  <div class="filter-bar">
    <span class="section-label">Filtrar:</span>
    <a href="/" class="fchip @(!Model.HasFilters ? "active" : "")">Todas</a>
    @foreach (Category c in Enum.GetValues<Category>())
    {
        <a href="@FiltroUrl("cat", ((int)c).ToString())" class="fchip @CatAtiva(c)">@c</a>
    }
    @foreach (DesktopEnv d in Enum.GetValues<DesktopEnv>())
    {
        <a href="@FiltroUrl("de", ((int)d).ToString())" class="fchip @DeAtiva(d)">@d</a>
    }
    <a href="@FiltroUrl("rolling", Model.Rolling == true ? null : "true")"
       class="fchip green @(Model.Rolling == true ? "active" : "")">✓ Rolling</a>
    @if (Model.HasFilters)
    {
        <a href="/" class="fchip red">✕ Limpar</a>
    }
  </div>

  @{
      var lista = Model.Distros.ToList();
      var delay = 0.05;
  }

  <div class="distro-grid">
    @if (!lista.Any())
    {
        <div class="vazio">
            <p>Nenhuma distribuição encontrada.</p>
            <a href="/" class="btn-lg-ghost" style="margin-top:1rem;">Ver todas</a>
        </div>
    }
    else
    {
        @foreach (var d in lista)
        {
            var featured = d.IsFeatured ? "featured" : "";
            <div class="distro-card @featured" style="animation-delay:@(delay.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))s">
              <div class="dc-top">
                <div class="dc-logo">🐧</div>
                <div class="dc-info">
                  <div class="dc-name">@d.Name</div>
                  <div class="dc-base">Base: @d.BasedOn · @(d.IsRolling ? "Rolling" : "Estável")</div>
                  <div class="dc-badges">
                    <span class="dc-badge badge-cyan">@d.PackageManager</span>
                    <span class="dc-badge badge-purple">@d.DesktopEnv</span>
                    @if (d.IsRolling)  { <span class="dc-badge badge-green">Rolling</span> }
                    @if (d.IsFeatured) { <span class="dc-badge badge-featured">★ Destaque</span> }
                  </div>
                </div>
              </div>
              @if (!string.IsNullOrWhiteSpace(d.Description))
              {
                  <div class="dc-desc">@d.Description</div>
              }
              <div class="dc-footer">
                <span class="dc-stat">📥 @d.DownloadCount</span>
                <span class="dc-ver">@d.LatestVersion</span>
                @if (!string.IsNullOrWhiteSpace(d.IsoDownloadUrl))
                {
                    <a href="@(string.IsNullOrEmpty(d.IsoDownloadUrl) ? "/planos" : d.IsoDownloadUrl)" target="_blank" rel="noopener noreferrer" class="dc-dl-btn">@(string.IsNullOrEmpty(d.IsoDownloadUrl) ? "🔓 Desbloquear Download" : "↓ ISO")</a>
                }
              </div>
            </div>
            delay += 0.05;
        }
    }
  </div>

  <div class="bottom-grid">
    <div class="b-card">
      <div class="b-header">
        <span class="b-title">// Downloads Recentes</span>
        <span style="font-size:11px;color:var(--green);font-family:monospace;">✓ SHA-256 verificado</span>
      </div>
      @foreach (var d in lista.OrderByDescending(x => x.DownloadCount).Take(5))
      {
          <div class="recent-item">
            <div class="ri-logo">🐧</div>
            <div>
              <div class="ri-name">@d.Name @d.LatestVersion</div>
              <div class="ri-version">@(d.Slug ?? d.Name.ToLower().Replace(" ","-"))-x86_64</div>
            </div>
            <span class="ri-size">@(FormatHelper.FormatSize(d.IsoSizeMb))</span>
            <span>✅</span>
          </div>
      }
    </div>
    <div class="b-card">
      <div class="b-header"><span class="b-title">// Sobre o DistroHub</span></div>
      <div class="upload-zone">
        <div class="upz-inner">
          <div class="upz-icon">🐧</div>
          <div class="upz-title">Catálogo Open Source</div>
          <div class="upz-desc">O maior catálogo brasileiro de distribuições Linux, com ISOs verificados por checksum SHA-256.</div>
        </div>
      </div>
    </div>
  </div>
</div>

</body>
</html>
